# .env — Agente Buscador · Brain MRO Master Pro
# Copia este archivo como .env y llena los valores

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (usa el Service Role Key, no el anon key)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# 1CRM — mromasterpro.1crmcloud.com
ONECRM_URL=https://mromasterpro.1crmcloud.com
ONECRM_CLIENT_ID=
ONECRM_CLIENT_SECRET=
ONECRM_USERNAME=
ONECRM_PASSWORD=

# Google Custom Search
# 1. Crea una API key en console.cloud.google.com
# 2. Crea un Custom Search Engine en cse.google.com
GOOGLE_API_KEY=
GOOGLE_CX=

# Tipo de cambio (opcional — fixer.io)
# Si no lo pones, usa 17.50 como fallback
FX_API_KEY=
