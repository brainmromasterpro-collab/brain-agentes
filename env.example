# .env — Agentes Brain MRO Master Pro
# Copia este archivo como .env y llena los valores

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (usa el Service Role Key, no el anon key)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# 1CRM — mromasterpro.1crmcloud.com
ONECRM_URL=https://mromasterpro.1crmcloud.com
ONECRM_USERNAME=
ONECRM_PASSWORD=

# Google Custom Search (buscador + imágenes)
# 1. API key: console.cloud.google.com → Custom Search API
# 2. Search Engine ID: cse.google.com (activar "Búsqueda de imágenes")
GOOGLE_API_KEY=
GOOGLE_CX=

# SerpAPI (búsqueda web de precios)
SERPAPI_KEY=

# Remove.bg (remoción de fondo de imágenes)
# Cuenta en: https://www.remove.bg/dashboard#api-key
# Plan gratuito: 50 imágenes/mes
REMOVEBG_API_KEY=

# Tipo de cambio USD/MXN (opcional — fixer.io)
# Si no se configura, usa 17.50 como fallback
FX_API_KEY=
